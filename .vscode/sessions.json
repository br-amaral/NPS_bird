{
    "$schema": "https://cdn.statically.io/gh/nguyenngoclongdev/cdn/main/schema/v11/terminal-keeper.json",
    "theme": "tribe",
    "active": "default",
    "activateOnStartup": true,
    "keepExistingTerminals": false,
    "sessions": {
        "default": [
            {
                "name": "Github",
                "autoExecuteCommands": true,
                "icon": "logo-github",
                "color": "terminal.ansiBrightMagenta",
                "commands": [
                    "git status"
                ]
            },
            {
                "name": "HPCC",
                "autoExecuteCommands": true,
                "icon": "squirrel",
                "color": "terminal.ansiRed",
                "commands": [
                    "ssh -XY bamaral@hpcc.msu.edu"
                ]
            },
            {
                "name": "Mapped",
                "autoExecuteCommands": true,
                "icon": "location",
                "color": "terminal.ansiBrightGreen",
                "commands": [
                    "cd /Volumes/zipkinlab/bamaral/NPS_bird_copy"
                ]
            },
            {
                "name": "R local",
                "autoExecuteCommands": true,
                "icon": "run",
                "color": "terminal.ansiBrightCyan",
                "commands": [
                    "cd ~/Library/Mobile\\ Documents/com~apple~CloudDocs/GitHub_data/dataNPS_bird_copy/",
                    "R"
                ]
            },
            {
                "name": "R mapped",
                "autoExecuteCommands": true,
                "icon": "run",
                "color": "terminal.ansiBrightCyan",
                "commands": [
                    "cd /Volumes/zipkinlab/bamaral/NPS_bird_copy",
                    "R"
                ]
            }
        ]
    }
}